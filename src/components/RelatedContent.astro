---
import type { RelatedContentGroup } from "@lib/content";

const { groups = [] } = Astro.props;
---

{
  groups.length > 0 && (
    <section class="related-content" aria-labelledby="related-content-heading">
      <h2 id="related-content-heading">Related Content</h2>
      {groups.map((group: RelatedContentGroup) => (
        <section class="related-group">
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => (
              <li>
                <div>
                  {item.meta && <p>{item.meta}</p>}
                  <h4>
                    {item.href ? <a href={item.href}>{item.title}</a> : item.title}
                  </h4>
                  {item.summary && <span>{item.summary}</span>}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </section>
  )
}
