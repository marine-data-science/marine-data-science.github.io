---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContentLink from "@components/ContentLink.astro";
import MetadataRows from "@components/MetadataRows.astro";
import PageIntro from "@components/PageIntro.astro";
import RelatedContent from "@components/RelatedContent.astro";
import { render } from "astro:content";
import { getEntries, getRelatedContentForPerson, hasLocalDetailPage, imageForEntry, metadataRowsForEntry, slugForEntry, summaryForEntry } from "@lib/content";

export async function getStaticPaths() {
  const entries = await getEntries("people");
  return entries.filter(hasLocalDetailPage).map((entry) => ({ params: { slug: slugForEntry(entry) }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const image = imageForEntry(entry);
const summary = summaryForEntry(entry);
const rows = await metadataRowsForEntry(entry);
const relatedContent = await getRelatedContentForPerson(entry);
const intro = summary || rows.find((row) => row.label === "Role")?.value || "";
---

<BaseLayout title={entry.data.title} description={summary}>
  <PageIntro eyebrow="Person" title={entry.data.title} intro={intro} />
  <section class="detail-shell">
    <article>
      {image && <img class="detail-image" src={image.src} alt={image.alt} />}
      <MetadataRows rows={rows} />
      <div class="prose">
        <Content components={{ a: ContentLink }} />
      </div>
      <RelatedContent groups={relatedContent} />
    </article>
  </section>
</BaseLayout>
