---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageIntro from "@components/PageIntro.astro";
import Prose from "@components/Prose.astro";
import { getIndex, getPublicationsByYear } from "@lib/content";

const entry = await getIndex("publications");
const publications = await getPublicationsByYear();
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <PageIntro eyebrow="Publications" title="Publications" intro={entry.data.summary} />
  <section class="publications">
    {
      publications.map((group) => (
        <section class="publication-year">
          <h2>{group.year}</h2>
          <div class="publication-list">
            {group.items.map((item) => (
              <article>
                <Prose markdown={item} />
              </article>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
